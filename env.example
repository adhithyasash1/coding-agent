# By DEFAULT the agent talks to a local MLX server (configured in config.py) and
# needs NO environment setup. The variables below OVERRIDE those defaults — use
# them to point at a different local port/key, or at a cloud provider.
#
# Copy this file to .env (gitignored) and load it with:
#   set -a && source .env && set +a

# --- provider override (all optional) ---
# OPENAI_API_KEY=your-api-key                # or LLM_API_KEY
# OPENAI_BASE_URL=https://api.groq.com/openai/v1   # cloud; or http://localhost:PORT/v1 for local
# AGENT_MODEL=openai/gpt-oss-120b            # or any model id your provider serves
